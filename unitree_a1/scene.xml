<mujoco model="a1 scene">
  <include file="a1.xml"/>

  <statistic center="0 0 0.5" extent="5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
<material name="ring"        rgba="0.85 0.85 0.85 1"/>
    <material name="goal"        rgba="0.2  0.85 0.2  1"/>
  </asset>

  <worldbody>
    <light pos="0 0 6" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Ring markers — 24 cylinders every 15° at radius 3 m, non-colliding -->
    <geom type="cylinder" pos=" 3.000  0.000 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 2.898  0.776 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 2.598  1.500 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 2.121  2.121 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 1.500  2.598 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 0.776  2.898 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 0.000  3.000 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-0.776  2.898 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-1.500  2.598 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-2.121  2.121 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-2.598  1.500 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-2.898  0.776 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-3.000  0.000 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-2.898 -0.776 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-2.598 -1.500 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-2.121 -2.121 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-1.500 -2.598 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos="-0.776 -2.898 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 0.000 -3.000 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 0.776 -2.898 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 1.500 -2.598 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 2.121 -2.121 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 2.598 -1.500 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>
    <geom type="cylinder" pos=" 2.898 -0.776 0.04" size="0.07 0.04" material="ring" contype="0" conaffinity="0"/>

    <!-- Goal marker — mocap body so sim.py can move it to any ring position -->
    <body name="goal_marker" mocap="true" pos="3.0 0.0 0.04">
      <geom type="cylinder" size="0.2 0.04" material="goal" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
